# ========================================
# Security Headers for Hostinger (Apache)
# ========================================

# ========================================
# MIME Types
# ========================================

AddType audio/ogg .opus
AddType audio/ogg .ogg
AddType audio/mpeg .mp3

<FilesMatch "\.opus$">
    ForceType audio/ogg
</FilesMatch>

<IfModule mod_headers.c>
    # ---- Content Security Policy (severa) ----
    # default-src 'none': tutto e' negato salvo cio' che apriamo esplicitamente.
    # script-src 'self': NESSUN 'unsafe-inline' -> niente XSS via inline script.
    # style-src 'unsafe-inline': UNICA eccezione, necessaria per i tag <style>
    #   inline (boot splash in index.html + blocco <style> dinamico della
    #   LandingPage che interpola i colori del tema, quindi non hashabile).
    #   Rischio basso: nessun sink inietta CSS da input utente. Vedi SECURITY.md.
    # font/img/media/connect/worker/manifest: tutto 'self' (zero terze parti).
    #   I font sono self-hostati in /fonts; data: serve per gli SVG nei CSS.
    # object/frame-src 'none', frame-ancestors 'none', base-uri/form-action 'self'.
    Header always set Content-Security-Policy "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; media-src 'self'; manifest-src 'self'; worker-src 'self'; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"

    # Anti-clickjacking (ridondante con frame-ancestors, utile per browser legacy)
    Header always set X-Frame-Options "DENY"

    # Niente MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Disabilita il vecchio XSS Auditor: deprecato nel 2026, puo' introdurre falle.
    Header always set X-XSS-Protection "0"

    # Referrer ridotto
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Disattiva le API potenti non usate dal sito
    Header always set Permissions-Policy "accelerometer=(), autoplay=(self), camera=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), usb=(), interest-cohort=()"

    # Isolamento cross-origin del browsing context. COEP require-corp NON e'
    # applicato: richiederebbe CORP su ogni asset e non serve isolation qui.
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"

    # HSTS - 2 anni + preload (forza HTTPS, idoneo per hstspreload.org)
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

    # Non esporre info sul server
    Header unset X-Powered-By
    Header unset Server
    Header always unset X-Powered-By
</IfModule>

# ========================================
# Rewrite Rules per React Router (SPA)
# ========================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Non reindirizzare file esistenti
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l
    
    # Reindirizza tutto a index.html (React Router)
    RewriteRule . /index.html [L]
</IfModule>

# ========================================
# Compressione GZIP
# ========================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
</IfModule>

# ========================================
# Browser Caching
# ========================================

<IfModule mod_expires.c>
    ExpiresActive On
    
    # Immagini - 1 anno
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Font - 1 anno
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    
    # Audio - 7 giorni
    ExpiresByType audio/ogg "access plus 7 days"
    ExpiresByType audio/mpeg "access plus 7 days"

    # CSS e JavaScript - 1 mese
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # HTML - 1 ora
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ========================================
# Blocca accesso a file sensibili
# ========================================

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(env|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>
