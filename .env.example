# ========================================
# VIHENTE - Environment Variables Example
# ========================================
#
# Copia questo file in .env e compila con i tuoi valori
# IMPORTANTE: Non committare mai il file .env su Git!

# ========================================
# API Configuration
# ========================================

# Endpoint API per form contatti (futuro)
VITE_API_URL=https://your-api.example.com/api

# API Key (se necessaria)
# VITE_API_KEY=your-api-key-here

# ========================================
# Analytics & Monitoring (Opzionale)
# ========================================

# Google Analytics Measurement ID
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics (alternativa privacy-friendly)
# VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# Sentry DSN per error tracking
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ========================================
# Feature Flags (Opzionale)
# ========================================

# Abilita modalità debug
# VITE_DEBUG_MODE=false

# Abilita NavigationDebugPanel
# VITE_SHOW_DEBUG_PANEL=false

# ========================================
# Email Service (Futuro)
# ========================================

# SendGrid API Key
# VITE_SENDGRID_API_KEY=SG.xxxxx

# Mailgun API Key
# VITE_MAILGUN_API_KEY=xxxxx

# Email destinatario per form contatti
# VITE_CONTACT_EMAIL=info@example.com

# ========================================
# Social & External Services
# ========================================

# Google reCAPTCHA Site Key
# VITE_RECAPTCHA_SITE_KEY=xxxxx

# Facebook Pixel ID
# VITE_FB_PIXEL_ID=xxxxx

# ========================================
# Build Configuration
# ========================================

# Base URL per deployment (automatico)
# VITE_BASE_URL=/

# Node environment (automatico)
# NODE_ENV=development|production

# ========================================
# Nota
# ========================================
# Tutte le variabili che iniziano con VITE_ sono accessibili
# nel frontend tramite import.meta.env.VITE_NOME_VARIABILE
#
# Le variabili senza VITE_ sono accessibili solo nel build script
# ========================================
